{
  "expo": {
    "name": "EduGenie",
    "slug": "edugenie",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "edugenie",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": { "backgroundColor": "#2563EB" },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.edugenie.learnspace"
    },
    "android": {
      "package": "io.edugenie.learnspace"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@stripe/stripe-react-native",
      "expo-notifications",
      "expo-linking"
    ]
  }
}
