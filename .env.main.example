# ─── EduGenie OS — Production Environment ─────────────────────────────
# Copy to your production secret store.
# Use production Supabase project, live Stripe keys, and real API keys.

ENVIRONMENT=production

# ─── Supabase (Unified: DB + Storage + Auth) ─────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ─── Google AI ───────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Stripe (use live mode keys) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_CONNECT_CLIENT_ID=ca_

# ─── SendGrid ────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.

# ─── Twilio WhatsApp ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=+14155551234

# ─── Algolia ─────────────────────────────────────────────────────────────
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=
ALGOLIA_INDEX_NAME=edugenie_courses_prod

# ─── Optional: Voice Cloning ─────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ─── Optional: Observability ─────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
POSTHOG_API_KEY=phc_

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://<your-redis-host>:6379

# ─── Optional: Event Streaming ───────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_API_KEY=
KAFKA_API_SECRET=

# ─── App ─────────────────────────────────────────────────────────────────
APP_NAME=EduGenie API
APP_VERSION=0.2.0
DEBUG=false
