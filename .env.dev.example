# ─── EduGenie OS — Development Environment ───────────────────────────────
# Copy to .env and fill in your local values.
# Supabase local or remote project for development.

ENVIRONMENT=development

# ─── Supabase (Unified: DB + Storage + Auth) ─────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ─── Google AI ───────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Stripe (use test mode keys) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_CONNECT_CLIENT_ID=ca_

# ─── SendGrid ────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.

# ─── Twilio WhatsApp ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=+14155551234

# ─── Algolia ─────────────────────────────────────────────────────────────
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=
ALGOLIA_INDEX_NAME=edugenie_courses_dev

# ─── Optional: Voice Cloning ─────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ─── Optional: Observability ─────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
POSTHOG_API_KEY=phc_

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Database (local or dev Supabase) ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/edugenie

# ─── App ─────────────────────────────────────────────────────────────────
APP_NAME=EduGenie API (Dev)
APP_VERSION=0.2.0
DEBUG=true
